@page "/ExternalLogin"
@using DarkSun.Application.Interfaces
@using DarkSun.Domain.Entities
@using Microsoft.AspNetCore.Components.Web
@using MudBlazor
@inject IUserService UserService
@inject NavigationManager Navigation
@inject ILogger<ExternalLogin> Logger

<PageTitle>External Login</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-10">
    <MudPaper Class="pa-8" Elevation="4">
        <MudText Typo="Typo.h5" Align="Align.Center">Processing external login...</MudText>
        <MudProgressCircular Indeterminate="true" Class="mx-auto mt-4" />
    </MudPaper>
</MudContainer>

@code {
    [Parameter]
    [SupplyParameterFromQuery]public string? Provider { get; set; }

    [Parameter]
    [SupplyParameterFromQuery]public string? ReturnUrl { get; set; } = "/character";

    protected override void OnInitialized()
    {
        var target = string.IsNullOrWhiteSpace(ReturnUrl) || ReturnUrl == "/"
                     ? "/character"
                     : ReturnUrl;

        Navigation.NavigateTo(target, forceLoad: true);
    }
