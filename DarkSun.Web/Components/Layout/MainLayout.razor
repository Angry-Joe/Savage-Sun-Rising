@* MainLayout.razor *@
@inherits LayoutComponentBase
@using MudBlazor
@using Microsoft.AspNetCore.Components.Authorization

<MudThemeProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1">
        <MudIcon Icon="@Icons.Material.Filled.MenuBook" Class="mr-3" />
        <MudText Typo="Typo.h5" Class="ml-2">Dark Sun Character Builder</MudText>
        <MudSpacer />
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/spells">Spell Browser</MudButton>
        <AuthorizeView>
            <Authorized>
                <MudText Class="mx-4" Typo="Typo.body2">@context.User.Identity?.Name</MudText>
                <MudButton Variant="Variant.Outlined" Color="Color.Secondary" Href="/logout">Logout</MudButton>
            </Authorized>
            <NotAuthorized>
                <MudButton Variant="Variant.Outlined" Color="Color.Primary" Href="/login">Login</MudButton>
            </NotAuthorized>
        </AuthorizeView>
    </MudAppBar>

    <MudDrawer Open="true" Elevation="2" ClipMode="DrawerClipMode.Docked">
        <MudNavMenu>
            <MudNavLink Href="/" Icon="@Icons.Material.Filled.Home">Home</MudNavLink>
            <MudNavLink Href="/spells" Icon="@Icons.Material.Filled.MenuBook">Spells</MudNavLink>
            <MudNavLink Href="/character" Icon="@Icons.Material.Filled.Person">Character Builder</MudNavLink>
        </MudNavMenu>
    </MudDrawer>

    <MudMainContent>
        @Body
    </MudMainContent>
</MudLayout>
