@* App.razor *@
<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <base href="/" />
        <link rel="stylesheet" href="bootstrap/bootstrap.min.css" />
        <link rel="stylesheet" href="app.css" />
        <link href="DarkSun.Web.styles.css" rel="stylesheet" />
        <link href="_content/MudBlazor/MudBlazor.min.css" rel="stylesheet" />
        <link rel="icon" type="image/png" href="favicon.png" />

        @* Set the global render mode for the head, without prerendering *@
        <HeadOutlet @rendermode="@(new InteractiveServerRenderMode(prerender: false))" />
    </head>

    <body>
        @* CascadingAuthenticationState provides auth data to all components *@
        <CascadingAuthenticationState>

            @* Define the routes only ONCE, without prerendering *@
            <Routes @rendermode="@(new InteractiveServerRenderMode(prerender: false))" />

        </CascadingAuthenticationState>

        <script src="_content/MudBlazor/MudBlazor.min.js"></script>
        <script src="_framework/blazor.web.js"></script>
    </body>
</html>
