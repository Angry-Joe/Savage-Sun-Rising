@* Character.razor *@
@page "/character"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using MudBlazor
@* New additions for list of player's' characters *@
@using DarkSun.Domain.Entities
@* @using DarkSun.Application.State *@
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@* @rendermode InteractiveServer *@
@inject NavigationManager Navigation
@inject ICharacterService CharacterService   // We'll create this
@inject ILogger<Character> Logger
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Character Builder – Dark Sun</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-8">
    <MudText Typo="Typo.h3" GutterBottom="true">My Characters</MudText>

    <MudButton Variant="Variant.Filled"
               Color="Color.Primary"
               Size="Size.Large"
               OnClick="CreateNewCharacter"
               Class="mb-6">
        + Create New Character
    </MudButton>

    <MudDivider Class="my-6" />

    <!-- Existing Characters Grid -->
    @if (_isLoading)
    {
        <MudProgressCircular Indeterminate="true" Class="my-8" />
        <MudText Class="mt-4">Loading your survivors under the crimson sun...</MudText>
    }
    else if (_errorMessage != null)
    {
        <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Class="mt-4">
            @_errorMessage
        </MudAlert>
        <MudButton OnClick="LoadCharacters" Class="mt-2">Retry</MudButton>
    }
    else if (_characters == null || !_characters.Any())
    {
        <MudText Typo="Typo.body1" Color="Color.Warning" Class="mt-4">
            You have no characters yet. Create your first one above!
        </MudText>
    }
    else
    {
        <MudGrid Spacing="4">
            @foreach (var character in _characters)
            {
                <MudItem xs="12" sm="6" md="4" lg="3">
                    <MudCard
                        Elevation="2"
                        Style="cursor: pointer; height: 100%;">
                             @* @onclick="() => OpenCharacter(character)"> *@
                        <MudCardHeader>
                            <CardHeaderContent>
                                <MudText Typo="Typo.h6">@character.Name</MudText>
                                <MudText Typo="Typo.body2" Color="Color.Secondary">
                                    @character.Race?.Name – @character.Class?.Name @character?.Level
                                </MudText>
                            </CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent>
                            <MudText Typo="Typo.body2" Class="mb-2">
                                @character.Background?.Name
                            </MudText>
                            <MudText Typo="Typo.caption" Color="Color.Info">
                                Last played: @character.UpdatedAt?.ToString("MMM dd, yyyy")
                            </MudText>
                        </MudCardContent>
                        <MudCardActions>
                            <MudButton Variant="Variant.Text"
                                       Color="Color.Primary"
                                       OnClick="() => OpenCharacter(character)">
                                View Character
                            </MudButton>
                        </MudCardActions>
                    </MudCard>
                </MudItem>
            }
        </MudGrid>
    }
</MudContainer>

    @code {
    @inject CharacterStateService CharacterState
    private List<CharacterSheet> _characters = new();
    private bool _isLoading = true;
    private string? _errorMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadCharacters();
    }

    private async Task LoadCharacters()
    {
        _isLoading = true;
        _errorMessage = null;

        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            // var userId = authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
            var userId = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;

            if (string.IsNullOrEmpty(userId))
            {
                Logger.LogWarning("No userId found — user not authenticated");
                _errorMessage = "Authentication error — please log in again.";
                return;
            }
            // _characters = await CharacterService.GetAllByUserAsync(userId) ?? new List<CharacterSheet>();
            _characters = await CharacterService.GetAllByUserAsync(userId) ?? new();
            Logger.LogInformation("Loaded {Count} characters for user {UserId}", _characters.Count, userId);
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to load characters: {ex.Message}";
            Logger.LogError(ex, "Failed to load characters");
        }
        finally
        {
            _isLoading = false;
            StateHasChanged(); // Ensure UI updates after loading characters
        }
    }

    private void CreateNewCharacter()
    {
        Navigation.NavigateTo("/character/create");
    }

    private void OpenCharacter(CharacterSheet character)
    {
        CharacterState.SetSelectedCharacter(character.CharId);

        // Navigation.NavigateTo($"/character/{character.CharId}");
        Navigation.NavigateTo("/character/detail");
        // Navigation.NavigateTo($"/character/{character.CharId}");
    }
}