    private void EditCharacter()
    {
        // Use the CharId from the URL parameter for navigation.
        if (!string.IsNullOrEmpty(CharId))
        {
            Navigation.NavigateTo($"/character/edit/{CharId}");
        }
    }

    private void BackToList() { Navigation.NavigateTo("/character"); }
