@* CharacteDetail.razor (Revised) *@
@* @page "/character/detail/{CharId}" *@
@page "/character/detail/{CharId}"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]

@using MudBlazor
@using DarkSun.Domain.Entities
@using System.Security.Claims
@using Microsoft.AspNetCore.WebUtilities
@inject NavigationManager Navigation
@inject Microsoft.AspNetCore.Components.Authorization.AuthenticationStateProvider AuthStateProvider
@inject ICharacterService CharacterService
@inject ILogger<CharacterDetail> Logger

<PageTitle>@(_character?.Name ?? "Loading...") – Dark Sun</PageTitle>

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-8">
    <div class="d-flex justify-space-between align-center mb-6">
        <MudText Typo="Typo.h3">@(_character?.Name ?? "Hero of Athas")</MudText>
        <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.ArrowBack" OnClick="BackToList">
            Back to Roster
        </MudButton>
    </div>

    @if (_isLoading)
    {
        <div class="d-flex justify-center my-16">
            <MudProgressCircular Color="Color.Primary" Size="Size.Large" Indeterminate="true" />
            <MudText Class="ml-4">The veiled masters consult the records...</MudText>
        </div>
    }
    else if (!string.IsNullOrEmpty(_loadError))
    {
        <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Class="my-4">
            @_loadError
        </MudAlert>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="BackToList">← Return to the Tablelands</MudButton>
    }
    else if (_character != null)
    {
        <MudCard Elevation="4">
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h4">@_character.Name</MudText>
                    <MudText Typo="Typo.body1" Color="Color.Secondary">
                        @_character.Race @_character.Class, Level @_character.Level
                    </MudText>
                </CardHeaderContent>
            </MudCardHeader>

            <MudCardContent>
                <MudGrid Spacing="4">
                    <MudGridItem xs="12" sm="6">
                        <MudText Typo="Typo.subtitle1">Background</MudText>
                        <MudText>@_character.Background</MudText>
                    </MudGridItem>
                    <MudGridItem xs="12" sm="6">
                        <MudText Typo="Typo.subtitle1">Alignment</MudText>
                        <MudText>@_character.Alignment</MudText>
                    </MudGridItem>

                    <MudGridItem xs="12">
                        <MudDivider />
                        <MudText Typo="Typo.h6" Class="mt-4 mb-2">Ability Scores</MudText>
                        <MudGrid Spacing="2">
                            @foreach (var score in _character.AbilityScores.OrderBy(s => s.Key))
                            {
                                <MudGridItem xs="6" sm="4" md="3">
                                    <MudText><strong>@score.Key</strong>: @score.Value</MudText>
                                </MudGridItem>
                            }
                        </MudGrid>
                    </MudGridItem>
                </MudGrid>
            </MudCardContent>

            <MudCardActions>
                <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="EditCharacter">
                    Edit Character
                </MudButton>
            </MudCardActions>
        </MudCard>
    }
</MudContainer>

@code {
    [Parameter]public string CharId { get; set; } = string.Empty;

    private CharacterSheet? _character;
    private bool _isLoading = true;
    private string? _loadError;
    // private string? _charId;

    protected override async Task OnParametersSetAsync()
    {
        // OnParametersSetAsync is the correct lifecycle method to use when a component parameter changes.
        await LoadCharacterDataAsync();
    }
