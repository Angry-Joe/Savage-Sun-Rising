@* RaceSelectionStep.razor *@
@using DarkSun.Domain.Entities
@using MudBlazor
@* Added for Name, Alignment, etc fields *@
@using System.ComponentModel.DataAnnotations

<MudContainer MaxWidth="MaxWidth.Large">
    <MudText Typo="Typo.h4" GutterBottom="true">Choose Your Race</MudText>
    <MudText Typo="Typo.subtitle1" Class="mb-4">The harsh wastes of Athas forge only the strongest.</MudText>

    <!-- Character Name (Required) -->
    <MudTextField Label="Character Name *"
                  @bind-Value="@CharacterName"
                  For="@(() => CharacterName)"
                  Variant="Variant.Outlined"
                  Class="mb-8"
                  Immediate="true"
                  Required="true"
                  MaxLength="60"
                  InputType="InputType.Text"
                  DebounceInterval="200" />

    <MudText Typo="Typo.h5" GutterBottom="true" Class="mt-6">Choose Your Race</MudText>
    <MudText Typo="Typo.subtitle1" Class="mb-4">The harsh wastes of Athas forge only the strongest.</MudText>

    @if (SelectedRace != null)
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mb-4">
            You have selected: <strong>@SelectedRace.Name</strong>
        </MudAlert>
    }

    <MudGrid Spacing="4">
        @foreach (var race in _availableRaces)
        {
            <MudItem xs="12" sm="6" md="4">
                <MudCard Elevation="@(SelectedRace?.Name == race.Name ? 8 : 4)"
                         Class="@(SelectedRace?.Name == race.Name ? "mud-theme-primary" : "")"
                         Style="cursor:pointer; height:100%;"
                         @onclick="() => SelectRace(race)">
                    <MudCardMedia Image="@race.ImageUrl" Height="180" />
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">@race.Name</MudText>
                            <MudText Typo="Typo.subtitle2" Color="Color.Secondary">@race.Subtype</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudText Typo="Typo.body2">@race.ShortDescription</MudText>
                        <MudChipSet T="string" Class="mt-3">
                            @foreach (var trait in race.KeyTraits)
                            {
                                <MudChip Size="Size.Small">@trait</MudChip>
                            }
                        </MudChipSet>
                    </MudCardContent>
                </MudCard>
            </MudItem>
        }
    </MudGrid>
</MudContainer>

@code {
    [Parameter]public string? CharacterName { get; set; }

    [Parameter]public EventCallback<string> CharacterNameChanged { get; set; }
    // public AthasianRace? SelectedRace { get; set; }
    // [Parameter] public string? CharacterName { get; set; }
    // [Parameter] public EventCallback<string> CharacterNameChanged { get; set; }

    [Parameter] public AthasianRace? SelectedRace { get; set; }
    [Parameter] public EventCallback<AthasianRace> SelectedRaceChanged { get; set; }

    // [Parameter]
    // public EventCallback<AthasianRace> SelectedRaceChanged { get; set; }

    private List<AthasianRace> _availableRaces = new()
    {
        new() {
            Name = "Human",
            Subtype = "Versatile Survivor",
            ShortDescription = "The most common people of the Tablelands — adaptable and ambitious.",
            KeyTraits = new[] { "+1 to any ability", "Extra skill", "Extra feat" },
            ImageUrl = "https://via.placeholder.com/300x180/8B4513/FFFFFF?text=Human"
        },
        new() {
            Name = "Elf",
            Subtype = "Desert Runner",
            ShortDescription = "Tall, lithe, and built for long-distance travel across the wastes.",
            KeyTraits = new[] { "+2 Dexterity", "Fleet of Foot", "Elf Run" },
            ImageUrl = "https://via.placeholder.com/300x180/556B2F/FFFFFF?text=Elf"
        },
        new() {
            Name = "Mul",
            Subtype = "Born Warrior",
            ShortDescription = "Sturdy half-dwarves bred for gladiatorial combat and hard labor.",
            KeyTraits = new[] { "+2 Strength", "+2 Constitution", "Tough" },
            ImageUrl = "https://via.placeholder.com/300x180/8B0000/FFFFFF?text=Mul"
        },
        new() {
            Name = "Half-Giant",
            Subtype = "Colossal Brute",
            ShortDescription = "Enormous descendants of giants — incredibly strong but impulsive.",
            KeyTraits = new[] { "+4 Strength", "+2 Constitution", "Powerful Build" },
            ImageUrl = "https://via.placeholder.com/300x180/4B0082/FFFFFF?text=Half-Giant"
        },
        new() {
            Name = "Thri-Kreen",
            Subtype = "Mantis Warrior",
            ShortDescription = "Insectoid hunters with four arms and natural chitin armor.",
            KeyTraits = new[] { "+2 Dexterity", "Natural Armor", "Four Arms" },
            ImageUrl = "https://via.placeholder.com/300x180/006400/FFFFFF?text=Thri-Kreen"
        }
    };

    protected override void OnInitialized()
    {
        Console.WriteLine($"🎲 RaceSelectionStep loaded with {_availableRaces.Count} races");
    }

    // This handles two-way binding for the name field
    // private async Task OnNameChanged(string? value)
    // {
    //     _localName = value;
    //     await CharacterNameChanged.InvokeAsync(value ?? string.Empty);
    // }
    private async Task SelectRace(AthasianRace race)
    {
        Console.WriteLine($"✅ Selected: {race.Name}");
        SelectedRace = race;
        await SelectedRaceChanged.InvokeAsync(race);
        // Re-sync the name so it doesn't disappear
        if (!string.IsNullOrEmpty(CharacterName))
            await CharacterNameChanged.InvokeAsync(CharacterName);
    }


}