@* @page "/character/create/race" *@
@using DarkSun.Application.Interfaces
@using DarkSun.Domain.Entities
@using MudBlazor
@inject ISpellRepository SpellRepo // placeholder for future

<MudContainer MaxWidth="MaxWidth.Large">
    <MudText Typo="Typo.h4" GutterBottom="true" Class="mb-6">Choose Your Race</MudText>
    <MudText Typo="Typo.subtitle1" Class="mb-8">The harsh wastes of Athas forge only the strongest.</MudText>

    <MudGrid Spacing="4">
        @foreach (var race in _availableRaces) {
            <MudItem xs="12" sm="6" md="4">
                <MudCard Elevation="4" Class="h-100" Style="cursor:pointer;" @onclick="async () => await SelectRace(race)">
                    <MudCardMedia Image="@race.ImageUrl" Height="180" />
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">@race.Name</MudText>
                            <MudText Typo="Typo.subtitle2" Color="Color.Secondary">@race.Subtype</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <p>@race.ShortDescription</p>
                        <MudChipSet T="string" Class="mt-3">
                            @foreach (var trait in race.KeyTraits) { <MudChip>@trait</MudChip> }
                        </MudChipSet>
                    </MudCardContent>
                </MudCard>
            </MudItem>
        }
    </MudGrid>
</MudContainer>

@code {
    [Parameter]
    public EventCallback OnNext { get; set; }

    private async Task SelectRace(AthasianRace race) {
        Console.WriteLine($"✅ Selected race: {race.Name}");
        // TODO: Save to shared character sheet later
        await OnNext.InvokeAsync();   // Advance to next step
        StateHasChanged(); // Force UI update
    }
    public class AthasianRace
    {
        public string Name { get; set; } = string.Empty;
        public string Subtype { get; set; } = string.Empty;
        public string ShortDescription { get; set; } = string.Empty;
        public string[] KeyTraits { get; set; } = Array.Empty<string>();
        public string ImageUrl { get; set; } = string.Empty;
    }
    private List<AthasianRace> _availableRaces = new() {
        new AthasianRace {
            Name = "Human",
            Subtype = "Versatile Survivor",
            ShortDescription = "The most common people of the Tablelands — adaptable and ambitious.",
            KeyTraits = new[] { "+1 to any ability", "Extra skill", "Extra feat" },
            ImageUrl = "https://via.placeholder.com/300x180/8B4513/FFFFFF?text=Human"
        },
        new AthasianRace {
            Name = "Elf",
            Subtype = "Desert Runner",
            ShortDescription = "Tall, lithe, and built for long-distance travel across the wastes.",
            KeyTraits = new[] { "+2 Dexterity", "Fleet of Foot", "Elf Run" },
            ImageUrl = "https://via.placeholder.com/300x180/556B2F/FFFFFF?text=Elf"
        },
        new AthasianRace {
            Name = "Mul",
            Subtype = "Born Warrior",
            ShortDescription = "Sturdy half-dwarves bred for gladiatorial combat and hard labor.",
            KeyTraits = new[] { "+2 Strength", "+2 Constitution", "Tough" },
            ImageUrl = "https://via.placeholder.com/300x180/8B0000/FFFFFF?text=Mul"
        },
        new AthasianRace {
            Name = "Half-Giant",
