@* BackgroundSelectionStep.razor *@
@using DarkSun.Domain.Entities
@using MudBlazor

<MudContainer MaxWidth="MaxWidth.Large">
    <MudText Typo="Typo.h4" GutterBottom="true" Class="mb-6">Choose Your Background</MudText>
    <MudText Typo="Typo.subtitle1" Class="mb-8">Every survivor on Athas has a past that forged them.</MudText>

    @if (SelectedBackground != null)
    {
        <MudAlert Severity="Severity.Success" Variant="Variant.Outlined" Class="mb-6">
            Selected: <strong>@SelectedBackground.Name</strong>
        </MudAlert>
    }

    <MudGrid Spacing="4">
        @foreach (var bg in AvailableBackgrounds)
        {
            <MudItem xs="12" sm="6" md="4">
                <MudCard @onclick="() => SelectBackground(bg)"
                         Elevation="@(SelectedBackground?.Id == bg.Id ? 12 : 3)"
                         Class="@(SelectedBackground?.Id == bg.Id ? "mud-border-primary border-2" : "")"
                         Style="cursor: pointer; height: 100%; transition: all 0.2s;">

                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">@bg.Name</MudText>
                            <MudText Typo="Typo.subtitle2" Color="Color.Secondary">@bg.Source</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    @* This block wsa from Grok, and he's been real flaky*@
                    @* <MudCardContent>
                        <p>@bg.ShortDescription</p>

                        <MudChipSet T="string" Class="mt-4">
                            @foreach (var skill in bg.Skills)
                            {
                                <MudChip>@skill</MudChip>
                            }
                        </MudChipSet>
                    </MudCardContent> *@
                    <MudCardContent>
                        <MudText Typo="Typo.body2" Class="mb-3">@bg.ShortDescription</MudText>

                        @if (bg.Skills.Length > 0)
                        {
                            <MudText Typo="Typo.caption"><strong>Skills:</strong> @string.Join(", ", bg.Skills)</MudText>
                        }
                        @if (bg.Tools.Length > 0)
                        {
                            <MudText Typo="Typo.caption"><strong>Tools:</strong> @string.Join(", ", bg.Tools)</MudText>
                        }
                        @if (!string.IsNullOrEmpty(bg.Feature))
                        {
                            <MudText Typo="Typo.caption" Class="mt-1"><strong>Feature:</strong> @bg.Feature</MudText>
                        }
                    </MudCardContent>
                </MudCard>
            </MudItem>
        }
    </MudGrid>
</MudContainer>

@code {
    [Parameter] public AthasianBackground? SelectedBackground { get; set; }
    [Parameter] public EventCallback<AthasianBackground> SelectedBackgroundChanged { get; set; }

    private List<AthasianBackground> AvailableBackgrounds { get; set; } = new();

    protected override void OnInitialized()
    {
        AvailableBackgrounds = AthasianBackgrounds.All.ToList();
    }

    private async Task SelectBackground(AthasianBackground bg)
    {
        Console.WriteLine($"✅ Selected: {bg.Name}");
        SelectedBackground = bg;
        await SelectedBackgroundChanged.InvokeAsync(bg);
        StateHasChanged();
    }
