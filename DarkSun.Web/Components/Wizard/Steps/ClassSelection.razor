            KeyTraits = new[] { "Martial Mastery", "Brutal Strike", "Survivalist" },
            ImageUrl = "https://via.placeholder.com/300x160/8B0000/FFFFFF?text=Gladiator"
        },
        new AthasianClass
        {
            Name = "Rogue",
            Role = "Dune Trader / Thief",
