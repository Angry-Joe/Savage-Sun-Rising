@page "/character/create/class"
@using DarkSun.Application.Interfaces
@using DarkSun.Domain.Entities
@using MudBlazor
@inject ISpellRepository SpellRepo // placeholder

<MudContainer MaxWidth="MaxWidth.Large">
    <MudText Typo="Typo.h4" GutterBottom="true" Class="mb-6">Choose Your Path</MudText>
    <MudText Typo="Typo.subtitle1" Class="mb-8">Athas demands strength, cunning, and will. What power will you wield?</MudText>

    <MudGrid Spacing="4">
        @foreach (var cls in _availableClasses) {
            <MudItem xs="12" sm="6" md="4">
                <MudCard Elevation="4" Class="h-100" Style="cursor:pointer;" @onclick="() => SelectClass(cls)">
                    <MudCardMedia Image="@cls.ImageUrl" Height="160" />
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">@cls.Name</MudText>
                            <MudText Typo="Typo.subtitle2" Color="Color.Secondary">@cls.Role</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <p>@cls.ShortDescription</p>
                        <MudChipSet T="string">
                            @foreach (var trait in cls.KeyTraits) { <MudChip>@trait</MudChip> }
                        </MudChipSet>
                    </MudCardContent>
                </MudCard>
            </MudItem>
        }
    </MudGrid>
</MudContainer>

@code {
    private List<AthasianClass> _availableClasses = new()
    {
        new AthasianClass
        {
            Name = "Psionicist",
            Role = "Mind Weaver",
            ShortDescription = "Master of the Way — bends reality with thought alone. The only power that cannot be defiled.",
