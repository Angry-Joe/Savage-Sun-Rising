@* ReviewStep.razor *@
@using DarkSun.Domain.Entities
@using DarkSun.Web.Components.Wizard.Steps
@using MudBlazor
@using Microsoft.AspNetCore.Components.Authorization
@inject ICharacterService CharacterService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthStateProvider

<MudContainer MaxWidth="MaxWidth.Large">
    <MudText Typo="Typo.h4" GutterBottom="true" Class="mb-6">Review Your Hero of Athas</MudText>
    <MudText Typo="Typo.subtitle1" Class="mb-8">The crimson sun judges the worthy. Let us see what you have forged.</MudText>

    <MudGrid Spacing="4">
        <!-- Race -->
        <MudItem xs="12" md="6">
            <MudCard Elevation="3">
                <MudCardHeader>
                    <CardHeaderContent><MudText Typo="Typo.h6">Race</MudText></CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    @if (Race != null)
                    {
                        <div class="d-flex align-center gap-4">
                            <MudAvatar Image="@Race.ImageUrl" Size="Size.Large" />
                            <div>
                                <MudText Typo="Typo.h5">@Race.Name</MudText>
                                <MudText Typo="Typo.subtitle2" Color="Color.Secondary">@Race.Subtype</MudText>
                            </div>
                        </div>
                    }
                    else
                    {
                        <MudText Color="Color.Error">No race selected</MudText>
                    }
                </MudCardContent>
            </MudCard>
        </MudItem>

        <!-- Class -->
        <MudItem xs="12" md="6">
            <MudCard Elevation="3">
                <MudCardHeader>
                    <CardHeaderContent><MudText Typo="Typo.h6">Class</MudText></CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    @if (Class != null)
                    {
                        <MudText Typo="Typo.h5">@Class.Name</MudText>
                        <MudText Typo="Typo.body2">@Class.ShortDescription</MudText>
                    }
                    else
                    {
                        <MudText Color="Color.Error">No class selected</MudText>
                    }
                </MudCardContent>
            </MudCard>
        </MudItem>

        <!-- Ability Scores -->
        <MudItem xs="12" md="6">
            <MudCard Elevation="3">
                <MudCardHeader>
                    <CardHeaderContent><MudText Typo="Typo.h6">Ability Scores</MudText></CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    @if (Scores != null && Scores.Any())
                    {
                        <MudSimpleTable Dense="true" Hover="true">
                            <tbody>
                                @foreach (var score in Scores)
                                {
                                    var mod = (score.Value - 10) / 2;
                                    var modDisplay = mod >= 0 ? $"+{mod}" : $"{mod}";
                                    <tr>
                                        <td><MudText Typo="Typo.body2">@score.Name</MudText></td>
                                        <td><MudText Typo="Typo.body1"><strong>@score.Value</strong></MudText></td>
                                        <td><MudText Typo="Typo.body2" Color="Color.Secondary">@modDisplay</MudText></td>
                                    </tr>
                                }
                            </tbody>
                        </MudSimpleTable>
                    }
                    else
                    {
                        <MudText Color="Color.Warning">No scores assigned</MudText>
                    }
                </MudCardContent>
            </MudCard>
        </MudItem>

        <!-- Background -->
        <MudItem xs="12" md="6">
            <MudCard Elevation="3">
                <MudCardHeader>
                    <CardHeaderContent><MudText Typo="Typo.h6">Background</MudText></CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    @if (Background != null)
                    {
                        <MudText Typo="Typo.h5">@Background.Name</MudText>
                        <MudText>@Background.ShortDescription</MudText>
                    }
                    else
                    {
                        <MudText Color="Color.Warning">No background selected</MudText>
                    }
                </MudCardContent>
            </MudCard>
        </MudItem>

        <!-- Equipment -->
        <MudItem xs="12">
            <MudCard Elevation="3">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">Equipment (@(Equipment?.Count ?? 0) items)</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    @if (Equipment != null && Equipment.Any())
                    {
                        <MudChipSet T="string">
                            @foreach (var item in Equipment)
                            {
                                <MudChip>@item.Name (@item.Cost)</MudChip>
                            }
                        </MudChipSet>
                    }
                    else
                    {
                        <MudText Typo="Typo.body2" Color="Color.Info">No equipment selected yet. The wastes are unforgiving...</MudText>
                    }
                </MudCardContent>
            </MudCard>
        </MudItem>
    </MudGrid>

    <div class="d-flex justify-end gap-4 mt-8">
        <MudButton Variant="Variant.Outlined" OnClick="OnCancel">Start Over</MudButton>
        <MudButton Variant="Variant.Filled"
                    Color="Color.Primary"
                    OnClick="HandleSave"
                    Disabled="_isSaving">
            @(_isSaving ? "Saving..." : "Save Hero to Athas and Complete")
        </MudButton>
    </div>
</MudContainer>

@code {
    [Parameter] public AthasianRace? Race { get; set; }
    [Parameter] public AthasianClass? Class { get; set; }
    [Parameter] public List<AbilityScoreStep.AbilityScore>? Scores { get; set; }
    [Parameter] public AthasianBackground? Background { get; set; }
    [Parameter] public List<AthasianEquipment>? Equipment { get; set; }
    [Parameter] public EventCallback OnSave { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }
    [Parameter] public CharacterSheet Character { get; set; } = default!;

    private async Task SaveCharacter()
    {
        if (Race == null) return;
        await OnSave.InvokeAsync();
    }
    private bool _isSaving;

    private async Task HandleSave()
    {
        if (Race == null) return;
        _isSaving = true;
        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var userId = authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

            if (string.IsNullOrEmpty(userId))
            {
                Navigation.NavigateTo("/login", forceLoad: true);
                return;
            }

            var character = new CharacterSheet
                {
                    Race          = Race!,
                    Class         = Class!,
                    AbilityScores = Scores?.ToDictionary(s => s.Name, s => s.Value) ?? new(),
                    Background    = Background!,
                    Equipment     = Equipment ?? new()
                };

            await CharacterService.SaveCharacterAsync(character, userId);
            Snackbar.Add("Hero saved to Athas!", Severity.Success);
            Navigation.NavigateTo("/");
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to save: {ex.GetType().Name} - {ex.Message}", Severity.Error);
            Console.Error.WriteLine(ex.ToString());
        }
        finally { _isSaving = false; }
    }
}
