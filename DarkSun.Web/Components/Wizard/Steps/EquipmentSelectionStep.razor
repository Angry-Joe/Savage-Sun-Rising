    [Parameter] public List<AthasianEquipment> SelectedEquipment { get; set; } = new();
    [Parameter] public EventCallback<List<AthasianEquipment>> SelectedEquipmentChanged { get; set; }

    private Dictionary<string, List<AthasianEquipment>> _equipmentByCategory = new();

    protected override void OnInitialized()
    {
        _equipmentByCategory = AthasianEquipmentSeed.All
            .GroupBy(e => e.Category)
            .ToDictionary(g => g.Key, g => g.ToList());
    }

    private async Task ToggleEquipment(AthasianEquipment item)
    {
        if (SelectedEquipment.Any(e => e.Id == item.Id))
            SelectedEquipment.RemoveAll(e => e.Id == item.Id);
        else
            SelectedEquipment.Add(item);

        await SelectedEquipmentChanged.InvokeAsync(SelectedEquipment);
        StateHasChanged();
    }

