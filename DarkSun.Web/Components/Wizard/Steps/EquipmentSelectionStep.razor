    <MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true" Class="mb-4">
        @foreach (var category in _equipmentByCategory.Keys)
        {
            <MudTabPanel Text="@category">
                <MudGrid Spacing="3" Class="mt-3">
                    @foreach (var item in _equipmentByCategory[category])
                    {
                        var isSelected = SelectedEquipment.Any(e => e.Id == item.Id);
                        <MudItem xs="12" sm="6" md="4">
                            <MudCard Elevation="@(isSelected ? 8 : 2)"
                                     Class="@(isSelected ? "mud-theme-primary" : "")"
                                     Style="height:100%;">
                                <MudCardHeader>
                                    <CardHeaderContent>
                                        <MudText Typo="Typo.h6">@item.Name</MudText>
                                        <MudText Typo="Typo.subtitle2" Color="Color.Secondary">@item.Cost · @item.Weight</MudText>
                                    </CardHeaderContent>
                                </MudCardHeader>
                                <MudCardContent>
                                    <MudText Typo="Typo.body2">@item.ShortDescription</MudText>
                                    @if (item.Properties.Length > 0)
                                    {
                                        <MudChipSet T="string" Class="mt-2">
                                            @foreach (var prop in item.Properties)
                                            {
                                                <MudChip Size="Size.Small">@prop</MudChip>
                                            }
                                        </MudChipSet>
                                    }
                                </MudCardContent>
                                <MudCardActions>
                                    <MudButton FullWidth="true"
                                               Variant="@(isSelected ? Variant.Filled : Variant.Outlined)"
                                               Color="@(isSelected ? Color.Error : Color.Primary)"
                                               OnClick="() => ToggleEquipment(item)">
                                        @(isSelected ? "Remove ✕" : "Add ✓")
                                    </MudButton>
                                </MudCardActions>
                            </MudCard>
                        </MudItem>
                    }
                </MudGrid>
            </MudTabPanel>
        }
    </MudTabs>
</MudContainer>

