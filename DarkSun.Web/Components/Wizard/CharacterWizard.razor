@page "/character/create"
@using DarkSun.Domain.Entities
@using DarkSun.Web.Components.Wizard.Steps
@using MudBlazor
@inherits OwningComponentBase

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">
    <MudText Typo="Typo.h3" GutterBottom="true" Class="mb-6">Create New Hero of Athas</MudText>

    <MudStepper ActiveIndex="@_currentStep" CompletedColor="Color.Success" Color="Color.Primary">
        <MudStep Title="Race" Icon="@Icons.Material.Filled.Person" />
        <MudStep Title="Class" Icon="@Icons.Material.Filled.School" />
        <MudStep Title="Ability Scores" Icon="@Icons.Material.Filled.FitnessCenter" />
        <MudStep Title="Background" Icon="@Icons.Material.Filled.Work" />
        <MudStep Title="Equipment" Icon="@Icons.Material.Filled.Inventory" />
        <MudStep Title="Review & Save" Icon="@Icons.Material.Filled.Save" />
    </MudStepper>

    <MudPaper Class="pa-6 mt-6" Elevation="3">
        @switch (_currentStep)
        {
            case 0: <RaceSelection OnNext="NextStep" /> break;
            case 1: <ClassSelection OnNext="NextStep" /> break;
            case 2: <AbilityScoreGenerator OnNext="NextStep" /> break;
            @* case 3: <BackgroundSelection OnNext="NextStep" /> break;
            case 4: <EquipmentSelector OnNext="NextStep" /> break;
            case 5: <ReviewStep OnSave="SaveCharacter" /> break; *@
            default: <MudText Typo="Typo.h5">Step @_currentStep coming soon...</MudText>break;
        }
    </MudPaper>

    <MudGrid Class="mt-4">
        <MudItem xs="6">
            <MudButton Variant="Variant.Outlined" OnClick="PreviousStep" Disabled="@(_currentStep == 0)">Previous</MudButton>
        </MudItem>
        <MudItem xs="6" Class="text-right">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="NextStep" Disabled="@(_currentStep == 5)">Next</MudButton>
        </MudItem>
    </MudGrid>
</MudContainer>

@code {
    private int _currentStep = 0;
    private CharacterSheet _character = new();

    private void NextStep() => _currentStep = Math.Min(_currentStep + 1, 5);
    private void PreviousStep() => _currentStep = Math.Max(_currentStep - 1, 0);

    private async Task SaveCharacter()
    {
        // TODO: Save to DynamoDB via service
        Console.WriteLine($"Character saved: {_character.Name}");
        // Navigation to character sheet
    }
}