# =============================================
# Savage-Sun-Setting - Optimized .dockerignore
# =============================================

# === Ignore everything by default ===
**

# === Allow solution file ===
!*.slnx

# === Allow project source files ===
!DarkSun.Web/**
!DarkSun.Application/**
!DarkSun.Domain/**
!DarkSun.Infrastructure/**

# === OVERRIDE: Re-exclude build artifacts and sensitive runtime key material (must come AFTER the allow rules) ===
# The ** prefix is required to override the allow rules above
**/bin/**
**/obj/**
**/bin/
**/obj/
**/DataProtection-Keys/**

# === Ignore secrets and IDE files ===
**/.vs/
**/*.user
**/appsettings.Development.json
**/.git/
**/.gitignore
**/*.md
.git/
DarkSun.Tests/
Dockerfile
docker-compose.yml

.env
.vs
.vscode
