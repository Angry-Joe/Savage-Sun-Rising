{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DarkSunSpell",
  "type": "object",
  "description": "Canonical schema for every spell in the Dark Sun 5e character builder (Priest elemental spheres, Wizard defiler/preserver, future psionic powers, etc.)",
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique DynamoDB partition key (e.g., 'spell:create-water')"
    },
    "name": { "type": "string" },
    "type": { "const": "Spell" },
    "level": { "type": "integer", "minimum": 0, "maximum": 10 },
    "spheres": {
      "type": "array",
      "items": { "type": "string", "enum": ["Earth", "Air", "Fire", "Water", "Cosmos"] },
      "description": "Priest elemental spheres (multiple allowed for some Cosmos spells)"
    },
    "school": {
      "type": "string",
      "description": "5e School of Magic (Evocation, Transmutation, etc.) or 'Divine' for priests"
    },
    "source": {
      "type": "string",
      "description": "Exact book + page (e.g., 'Dark Sun Revised Campaign Setting p.194' or 'Dragon Kings p.87')"
    },
    "castingTime": { "type": "string" },
    "range": { "type": "string" },
    "components": { "type": "string" },
    "material": { "type": "string" },
    "duration": { "type": "string" },
    "concentration": { "type": "boolean" },
    "ritual": { "type": "boolean" },
    "description": { "type": "string" },
    "atHigherLevels": { "type": "string" },
    "athasianNotes": {
      "type": "string",
      "description": "Dark Sun-specific flavor or mechanical changes (e.g., 'Defiler casting leaves a 5-ft radius of ash')"
    },
    "flavorText": { "type": "string", "maxLength": 400 },
    "artworkPrompt": { "type": "string" },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "description": "e.g. ['#priest', '#earth', '#elemental', '#defiler']"
    },
    "relatedEntries": {
      "type": "array",
      "items": { "type": "string" },
      "description": "IDs of related spells, classes, or monsters"
    },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" }
  },
  "required": ["id", "name", "level", "spheres", "school", "source", "description"],
  "additionalProperties": false
}
